<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ESP32Controller.ViewModels"
             x:Class="ESP32Controller.Views.SensoresPage"
             x:DataType="vm:SensoresViewModel"
             Title="{Binding Titulo}">
    
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            
            <!-- Cabeçalho com modo e atualização -->
            <Frame CornerRadius="10" Padding="15" BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2C2C2C}">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                    <Label Text="Modo de Conexão" FontAttributes="Bold" />
                    <Switch Grid.Column="1" IsToggled="{Binding UsarWiFi}" />
                    <Label Grid.Row="1" Text="{Binding ModoTexto}" 
                           TextColor="{StaticResource Primary}" FontSize="12"/>
                </Grid>
            </Frame>
            
            <!-- Status de feedback -->
            <Label Text="{Binding StatusMensagem}" 
                   FontSize="13" 
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=#555555, Dark=#CCCCCC}"/>
            
            <!-- Botões de Controle -->
            <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10">
                <Button Text="🔄 Atualizar" 
                        Command="{Binding AtualizarCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"/>
                <Button Grid.Column="1"
                        Text="🌐 MQTT"
                        Command="{Binding ConectarMQTTCommand}"
                        BackgroundColor="{Binding MqttConectado, Converter={StaticResource BoolToColorConverter}}"
                        TextColor="White"
                        WidthRequest="90"
                        CornerRadius="8"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"/>
                <Button Grid.Column="2" 
                        Text="{Binding AtualizacaoAutomatica, StringFormat='{0}'}"
                        Clicked="OnToggleAutoUpdate"
                        BackgroundColor="{Binding AtualizacaoAutomatica, Converter={StaticResource BoolToColorConverter}}"/>
            </Grid>
            
            <!-- Indicador de carregamento -->
            <ActivityIndicator IsRunning="{Binding IsBusy}" 
                              IsVisible="{Binding IsBusy}"
                              HorizontalOptions="Center" />
            
            <!-- Card BME280 - Temperatura, Umidade e Pressão -->
            <Frame IsVisible="{Binding TemDados}" CornerRadius="15" Padding="20" 
                   BackgroundColor="{AppThemeBinding Light=#E3F2FD, Dark=#1E3A5F}" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🌡️ BME280 - Sensor de Precisão Alta" 
                           FontSize="18" FontAttributes="Bold" />
                    <Label Text="I2C: GPIO 21 (SDA) / GPIO 22 (SCL)" 
                           FontSize="10" Opacity="0.6" Margin="0,-5,0,0"/>
                    <BoxView HeightRequest="1" Color="{StaticResource Primary}" Opacity="0.3"/>
                    
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="15" Margin="0,10,0,0">
                        <VerticalStackLayout>
                            <Label Text="Temperatura" FontSize="12" Opacity="0.7"/>
                            <Label Text="{Binding Dados.TemperaturaFormatada}" 
                                   FontSize="22" FontAttributes="Bold" TextColor="{StaticResource Primary}"/>
                        </VerticalStackLayout>
                        
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Umidade" FontSize="12" Opacity="0.7"/>
                            <Label Text="{Binding Dados.UmidadeFormatada}" 
                                   FontSize="22" FontAttributes="Bold" TextColor="#2196F3"/>
                        </VerticalStackLayout>
                        
                        <VerticalStackLayout Grid.Column="2">
                            <Label Text="Pressão" FontSize="12" Opacity="0.7"/>
                            <Label Text="{Binding Dados.PressaoFormatada}" 
                                   FontSize="18" FontAttributes="Bold" TextColor="#FF9800"/>
                        </VerticalStackLayout>
                    </Grid>
                    
                    <!-- Informações adicionais sobre pressão -->
                    <Frame CornerRadius="8" Padding="10" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A3A5F}" 
                           Margin="0,10,0,0" BorderColor="#FF9800">
                        <Label Text="✓ Sensor de alta precisão 3.3V - Ideal para medições atmosféricas precisas" 
                               FontSize="11" Opacity="0.8" LineBreakMode="WordWrap"/>
                    </Frame>
                </VerticalStackLayout>
            </Frame>

            <!-- Card DHT22 - Temperatura e Umidade -->
            <Frame IsVisible="{Binding TemDados}" CornerRadius="15" Padding="20" 
                   BackgroundColor="{AppThemeBinding Light=#EFFFD4, Dark=#3A5F1E}" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🌡️ DHT22 - Sensor Digital" 
                           FontSize="18" FontAttributes="Bold" />
                    <Label Text="GPIO: 4 (Digital com resistor 4.7kΩ)" 
                           FontSize="10" Opacity="0.6" Margin="0,-5,0,0"/>
                    <BoxView HeightRequest="1" Color="#4CAF50" Opacity="0.3"/>
                    
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="20" Margin="0,10,0,0">
                        <VerticalStackLayout>
                            <Label Text="Temperatura" FontSize="12" Opacity="0.7"/>
                            <Label Text="{Binding Dados.TemperaturaDHT22Formatada}" 
                                   FontSize="22" FontAttributes="Bold" TextColor="#4CAF50"/>
                        </VerticalStackLayout>
                        
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Umidade" FontSize="12" Opacity="0.7"/>
                            <Label Text="{Binding Dados.UmidadeDHT22Formatada}" 
                                   FontSize="22" FontAttributes="Bold" TextColor="#66BB6A"/>
                        </VerticalStackLayout>
                    </Grid>
                    
                    <!-- Informações adicionais DHT22 -->
                    <Frame CornerRadius="8" Padding="10" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A3A5F}" 
                           Margin="0,10,0,0" BorderColor="#4CAF50">
                        <Label Text="✓ Sensor digital econômico - Ótimo custo-benefício para medições de umidade/temperatura" 
                               FontSize="11" Opacity="0.8" LineBreakMode="WordWrap"/>
                    </Frame>
                </VerticalStackLayout>
            </Frame>

            <!-- Card UV - GUVA-S12SD -->
            <Frame IsVisible="{Binding TemDados}" CornerRadius="15" Padding="20" 
                   BackgroundColor="{AppThemeBinding Light=#FFF3E0, Dark=#5F4A1E}" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="☀️ GUVA-S12SD - Sensor de Radiação UV" 
                           FontSize="18" FontAttributes="Bold" />
                    <Label Text="GPIO 34 (Analógico)" 
                           FontSize="10" Opacity="0.6" Margin="0,-5,0,0"/>
                    <BoxView HeightRequest="1" Color="#FF9800" Opacity="0.3"/>
                    
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="20" Margin="0,10,0,0">
                        <VerticalStackLayout>
                            <Label Text="Índice UV" FontSize="12" Opacity="0.7"/>
                            <Label Text="{Binding Dados.IndiceUVFormatado}" 
                                   FontSize="28" FontAttributes="Bold" 
                                   TextColor="{Binding Dados.CorUV}"/>
                        </VerticalStackLayout>
                        
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="Classificação" FontSize="11" Opacity="0.7"/>
                            <Label Text="{Binding Dados.ClassificacaoUV}" 
                                   FontSize="16" FontAttributes="Bold"/>
                            <Label Text="{Binding Dados.NivelUV, StringFormat='ADC: {0:N0}'}" 
                                   FontSize="10" Opacity="0.6" Margin="0,5,0,0"/>
                        </VerticalStackLayout>
                    </Grid>
                    
                    <!-- Escala de UV -->
                    <Frame CornerRadius="8" Padding="10" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A3A5F}" 
                           Margin="0,10,0,0" BorderColor="#FF9800">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Escala UV:" FontSize="10" FontAttributes="Bold" Opacity="0.7"/>
                            <Grid ColumnDefinitions="30,30,30,30,30" ColumnSpacing="2">
                                <Label Text="🟢" FontSize="14" HorizontalOptions="Center" ToolTipProperties.Text="0-2: Baixo"/>
                                <Label Text="🟡" FontSize="14" HorizontalOptions="Center" Grid.Column="1" ToolTipProperties.Text="3-5: Moderado"/>
                                <Label Text="🟠" FontSize="14" HorizontalOptions="Center" Grid.Column="2" ToolTipProperties.Text="6-7: Alto"/>
                                <Label Text="🔴" FontSize="14" HorizontalOptions="Center" Grid.Column="3" ToolTipProperties.Text="8-10: Muito Alto"/>
                                <Label Text="🟣" FontSize="14" HorizontalOptions="Center" Grid.Column="4" ToolTipProperties.Text="11+: Extremo"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>
            </Frame>
            
            <Frame IsVisible="{Binding TemDados}" CornerRadius="15" Padding="20" 
                   BackgroundColor="{AppThemeBinding Light=#FFF3E0, Dark=#5F3A1E}" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="💨 MQ-5 - Sensor de Gás (GPL/Isobutano)" 
                           FontSize="18" FontAttributes="Bold" />
                    <Label Text="Pino: GPIO 34 (Analógico)" 
                           FontSize="10" Opacity="0.6" Margin="0,-5,0,0"/>
                    <BoxView HeightRequest="1" Color="#FF9800" Opacity="0.3"/>
                    
                    <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,0">
                        <VerticalStackLayout>
                            <Label Text="Nível de Gás" FontSize="12" Opacity="0.7"/>
                            <Label Text="{Binding Dados.NivelGas, StringFormat='{0:N0}'}" 
                                   FontSize="24" FontAttributes="Bold" TextColor="#FF9800"/>
                            <ProgressBar Progress="{Binding Dados.NivelGas, Converter={StaticResource GasToProgressConverter}}"
                                        ProgressColor="#FF9800" Margin="0,5"/>
                        </VerticalStackLayout>
                        
                        <Label Grid.Column="1" Text="{Binding Dados.NivelGasTexto}"
                               FontSize="16" FontAttributes="Bold" VerticalOptions="Center"
                               TextColor="{Binding Dados.AlertaGas, Converter={StaticResource AlertToColorConverter}}"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>
            
            <!-- Card Detector de Chama -->
            <Frame IsVisible="{Binding TemDados}" CornerRadius="15" Padding="20" 
                   BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A1A1A}" 
                   HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🔥 Detector de Fogo / Chama" 
                           FontSize="18" FontAttributes="Bold" />
                    <Label Text="Pino: não conectado" 
                           FontSize="10" Opacity="0.6" Margin="0,-5,0,0"/>
                    <BoxView HeightRequest="2" Color="{Binding Dados.ChamaDetectada, Converter={StaticResource AlertToColorConverter}}" />
                    
                    <Frame CornerRadius="10" Padding="15" 
                           BackgroundColor="{Binding Dados.ChamaDetectada, Converter={StaticResource ChamaToDetailBackgroundConverter}}"
                           Margin="0,10,0,0">
                        <Label Text="{Binding Dados.ChamaTexto}" 
                               FontSize="32" FontAttributes="Bold" 
                               TextColor="{Binding Dados.ChamaDetectada, Converter={StaticResource AlertToColorConverter}}"
                               HorizontalOptions="Center" />
                    </Frame>
                </VerticalStackLayout>
            </Frame>
            
            <!-- Card LDR HW-072 - Luminosidade -->
            <Frame IsVisible="{Binding TemDados}" CornerRadius="15" Padding="20"
                   BackgroundColor="{AppThemeBinding Light=#FFFDE7, Dark=#5F5A1E}" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="💡 HW-072 - Sensor de Luminosidade (LDR)"
                           FontSize="18" FontAttributes="Bold" />
                    <Label Text="GPIO 35 (Analógico, input-only)"
                           FontSize="10" Opacity="0.6" Margin="0,-5,0,0"/>
                    <BoxView HeightRequest="1" Color="#FFC107" Opacity="0.3"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="20" Margin="0,10,0,0">
                        <VerticalStackLayout>
                            <Label Text="Luminosidade" FontSize="12" Opacity="0.7"/>
                            <Label Text="{Binding Dados.LdrPercentualFormatado}"
                                   FontSize="28" FontAttributes="Bold"
                                   TextColor="{Binding Dados.CorLDR}"/>
                            <ProgressBar Progress="{Binding Dados.LdrRaw, Converter={StaticResource GasToProgressConverter}}"
                                         ProgressColor="#FFC107" Margin="0,5"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="Descrição" FontSize="11" Opacity="0.7"/>
                            <Label Text="{Binding Dados.LdrDescricao}"
                                   FontSize="16" FontAttributes="Bold"/>
                            <Label Text="{Binding Dados.LdrMv, StringFormat='mV: {0:N0}'}"
                                   FontSize="10" Opacity="0.6" Margin="0,5,0,0"/>
                            <Label Text="{Binding Dados.LdrRaw, StringFormat='ADC: {0:N0}'}"
                                   FontSize="10" Opacity="0.6"/>
                        </VerticalStackLayout>
                    </Grid>

                    <Frame CornerRadius="8" Padding="10" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A1A}"
                           Margin="0,10,0,0" BorderColor="#FFC107">
                        <Label Text="✓ LDR: resistência diminui com luz → tensão maior = mais luminoso. Potenciômetro ajusta threshold do DO (não usado)."
                               FontSize="11" Opacity="0.8" LineBreakMode="WordWrap"/>
                    </Frame>
                </VerticalStackLayout>
            </Frame>

            <!-- Card KY-037 - Som -->
            <Frame IsVisible="{Binding TemDados}" CornerRadius="15" Padding="20" 
                   BackgroundColor="{AppThemeBinding Light=#F3E5F5, Dark=#4A1E5F}" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🔊 KY-037 - Detector de Som" 
                           FontSize="18" FontAttributes="Bold" />
                    <Label Text="Pino: GPIO 36 (Analógico)" 
                           FontSize="10" Opacity="0.6" Margin="0,-5,0,0"/>
                    <BoxView HeightRequest="1" Color="#9C27B0" Opacity="0.3"/>
                    
                    <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,0">
                        <VerticalStackLayout>
                            <Label Text="Nível de Som" FontSize="12" Opacity="0.7"/>
                            <Label Text="{Binding Dados.NivelSom, StringFormat='{0:N0}'}" 
                                   FontSize="24" FontAttributes="Bold" TextColor="#9C27B0"/>
                            <ProgressBar Progress="{Binding Dados.NivelSom, Converter={StaticResource SomToProgressConverter}}"
                                        ProgressColor="#9C27B0" Margin="0,5"/>
                        </VerticalStackLayout>
                        
                        <Label Grid.Column="1" Text="{Binding Dados.NivelSomTexto}"
                               FontSize="16" FontAttributes="Bold" VerticalOptions="Center"
                               TextColor="#9C27B0"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>
            
            <!-- Info da última atualização -->
            <Label IsVisible="{Binding TemDados}" 
                   Text="{Binding Dados.UltimaAtualizacao, StringFormat='Última atualização: {0:HH:mm:ss}'}"
                   FontSize="12" Opacity="0.6" HorizontalOptions="Center" Margin="0,10"/>
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
