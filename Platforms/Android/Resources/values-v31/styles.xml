<?xml version="1.0" encoding="utf-8" ?>
<resources>
    <!-- Base application theme inheriting from Material Components for Android 12+ -->
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.DarkActionBar" />
    
    <style name="Maui.SplashTheme" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <item name="android:windowBackground">@drawable/maui_splash</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">false</item>
    </style>
</resources>
